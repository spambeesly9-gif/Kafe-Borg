---
import FacebookIcon from "./FacebookIcon.astro";

const navItems = [
  { href: "/", label: "Home" },
  { href: "/our-story/", label: "Our Story" },
  { href: "/coffee/", label: "Coffee" },
  { href: "/visit/", label: "Visit Us" },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b border-coffee-900/10 bg-paper/90 backdrop-blur">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-5 py-2 sm:px-8">
    <a href="/" class="flex items-center gap-2.5">
      <img src="/logo.svg" alt="Kafé Borg" class="h-16 w-auto sm:h-[4.5rem]" />
    </a>

    <nav class="hidden items-center gap-8 sm:flex">
      {
        navItems.map((item) => {
          const isActive =
            item.href === "/" ? currentPath === "/" : currentPath.startsWith(item.href);
          return (
            <a
              href={item.href}
              class={`font-body text-[15px] font-medium tracking-wide transition-colors hover:text-red-600 ${
                isActive ? "text-red-600" : "text-coffee-700"
              }`}
            >
              {item.label}
            </a>
          );
        })
      }
    </nav>

    <div class="hidden items-center gap-4 sm:flex">
      <a
        href="https://www.facebook.com/kafeborg"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Kafé Borg on Facebook"
        class="text-coffee-700 transition-colors hover:text-red-600"
      >
        <FacebookIcon class="h-5 w-5" />
      </a>
      <a
        href="/visit/"
        class="rounded-full border border-coffee-900/20 px-4 py-2 font-body text-sm font-semibold text-coffee-900 transition-colors hover:border-red-600 hover:text-red-600"
      >
        Find the shop
      </a>
    </div>

    <details class="relative sm:hidden">
      <summary
        class="flex h-9 w-9 cursor-pointer list-none items-center justify-center rounded-full border border-coffee-900/20 text-coffee-900"
        aria-label="Menu"
      >
        <svg width="18" height="14" viewBox="0 0 18 14" fill="none">
          <path d="M0 1H18M0 7H18M0 13H18" stroke="currentColor" stroke-width="1.6" />
        </svg>
      </summary>
      <nav
        class="absolute right-0 top-12 flex w-48 flex-col gap-1 rounded-2xl border border-coffee-900/10 bg-cream-50 p-3 shadow-soft"
      >
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class="rounded-lg px-3 py-2 font-body text-sm font-medium text-coffee-800 hover:bg-paper-deep"
            >
              {item.label}
            </a>
          ))
        }
        <a
          href="https://www.facebook.com/kafeborg"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 rounded-lg px-3 py-2 font-body text-sm font-medium text-coffee-800 hover:bg-paper-deep"
        >
          <FacebookIcon class="h-4 w-4" />
          Facebook
        </a>
      </nav>
    </details>
  </div>
</header>
