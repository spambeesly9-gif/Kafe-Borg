---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  class={className}
  viewBox="0 0 240 20"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  {
    Array.from({ length: 8 }).map((_, i) => (
      <ellipse
        cx={10 + i * 32}
        cy="10"
        rx="8"
        ry="5.5"
        transform={`rotate(${i % 2 === 0 ? -20 : 20} ${10 + i * 32} 10)`}
        fill="currentColor"
        opacity="0.85"
      />
    ))
  }
  {
    Array.from({ length: 8 }).map((_, i) => (
      <line
        x1={10 + i * 32}
        y1="5.5"
        x2={10 + i * 32}
        y2="14.5"
        transform={`rotate(${i % 2 === 0 ? -20 : 20} ${10 + i * 32} 10)`}
        stroke="var(--color-paper)"
        stroke-width="1.1"
      />
    ))
  }
</svg>
